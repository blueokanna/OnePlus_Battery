#!/sbin/sh
SKIPUNZIP=1
if [ -f /data/adb/magisk/util_functions.sh ]; then
    . /data/adb/magisk/util_functions.sh
    install_module
    exit 0
fi
if [ -f /data/adb/ksu/util_functions.sh ]; then
    . /data/adb/ksu/util_functions.sh
    install_module
    exit 0
fi
# Fallback manual install
mkdir -p "$MODPATH"
unzip -o "$ZIPFILE" module.prop system.prop service.sh post-fs-data.sh customize.sh -d "$MODPATH" >&2
[ -f "$MODPATH/customize.sh" ] && . "$MODPATH/customize.sh"
chmod 0755 "$MODPATH/service.sh" "$MODPATH/post-fs-data.sh"
exit 0
